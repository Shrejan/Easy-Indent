{
  "manifest_version": 3,
  "name": "posathe dala unda",
  "version": "1.0.0",
  "description": "A browser extension to ksbcl indent NEWWNFUTURE",
  "permissions": ["storage", "scripting", "activeTab", "tabs"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["https://ksbclonline.karnataka.gov.in/KSBCL/retailerView/RetailerIndent"],
  "js": ["contentScript.js"]
    }]
 ,
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "action": {
    "default_popup": "index.html",
    "default_icon": {
      "16": "icon-16.png",
      "48": "icon-48.png"
      
    }
  }
  
} 